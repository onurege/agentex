generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          String    @default("user") // user | authorized_user | super_admin
  active        Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Domain relations
  agentProfiles    AgentProfile[]
  boardRuns        BoardRun[]
  templates        BoardTemplate[]
  auditLogs        AuditLog[]       @relation("AuditActor")
  regulationReads  RegulationRead[]

  @@index([email])
  @@index([deletedAt])
}

// ─── NextAuth: Account (OAuth provider link) ──────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ─── NextAuth: Session (database-backed) ──────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── NextAuth: VerificationToken (schema compat) ──────

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Agent Profile ────────────────────────────────────

model AgentProfile {
  id      String  @id @default(cuid())
  agentKey String // "legal-counsel", "finance-director", etc.
  ownerId String? // null = global
  owner   User?   @relation(fields: [ownerId], references: [id])

  // Draft state — JSONB (not queried, UI form state)
  cvDraft     Json?
  promptDraft Json?
  cvLastSaved     DateTime?
  promptLastSaved DateTime?

  // Published → AgentVersion is source of truth
  currentVersionId String?
  currentVersion   AgentVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id])

  versions AgentVersion[] @relation("ProfileVersions")

  // Custom-agent identity — populated when a user creates their own
  // agent via the panel. System agents leave these nullable and rely
  // on BOARDROOM_AGENTS for their baseline metadata.
  displayName   String?
  title         String?
  avatar        String?
  expertise     String[] @default([])
  tone          String?
  isUserCreated Boolean  @default(false)
  archivedAt    DateTime?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([agentKey, ownerId])
  @@index([agentKey])
  @@index([ownerId])
  @@index([isUserCreated])
}

// ─── Agent Version (Immutable snapshot on publish) ────

model AgentVersion {
  id        String       @id @default(cuid())
  profileId String
  profile   AgentProfile @relation("ProfileVersions", fields: [profileId], references: [id])
  version   Int          // auto-increment per profile

  // Frozen CV at publish time
  cvSnapshot Json? // AgentCVData shape — immutable

  // Frozen Prompt at publish time
  systemPrompt String? @db.Text
  rolePrompt   String? @db.Text
  outputRules  String? @db.Text
  guardrails   String? @db.Text

  publishedAt DateTime @default(now())

  // Reverse nav — in practice 0 or 1
  currentOf    AgentProfile[]     @relation("CurrentVersion")
  runSnapshots RunAgentSnapshot[]

  @@unique([profileId, version])
  @@index([profileId])
}

// ─── Board Template ───────────────────────────────────

model BoardTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  emoji       String?
  agentKeys   String[] // ["legal-counsel", "finance-director"]
  ownerId     String?  // null = system preset
  owner       User?    @relation(fields: [ownerId], references: [id])
  deletedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([ownerId])
}

// ─── Board Run ────────────────────────────────────────

model BoardRun {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Document info (frozen at run time)
  documentName String
  documentType String
  documentSize Int
  contextNotes String? @db.Text

  // Run metadata
  analysisMode     String // "ai" | "ai-partial" | "fallback"
  modelInfo        String?
  pipelineMetadata Json? // stage timing, errors — diagnostic

  status      String   @default("running") // running | complete | failed
  startedAt   DateTime @default(now())
  completedAt DateTime?
  deletedAt   DateTime?

  // Relations
  agentSnapshots    RunAgentSnapshot[]
  opinions          AgentOpinion[]
  debateMoments     DebateMoment[]
  verdict           FinalVerdict?
  document          DocumentArtifact?
  editProposals     EditProposal[]
  arbitratedEdits   ArbitratedEdit[]
  redlineArtifacts  RedlineArtifact[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([startedAt])
}

// ─── Run <-> Agent Version (join table) ───────────────

model RunAgentSnapshot {
  id             String       @id @default(cuid())
  runId          String
  run            BoardRun     @relation(fields: [runId], references: [id], onDelete: Cascade)
  agentVersionId String
  agentVersion   AgentVersion @relation(fields: [agentVersionId], references: [id])
  agentKey       String // denormalized for quick access
  isChief        Boolean @default(false)

  @@unique([runId, agentKey])
  @@index([runId])
}

// ─── Document Artifact ────────────────────────────────

model DocumentArtifact {
  id       String   @id @default(cuid())
  runId    String   @unique
  run      BoardRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  fileName String
  fileType String
  fileSize Int
  fullText String?  @db.Text
  sections Json // DocumentSection[] — parsed structure
  metadata Json // extraction quality, parser info
  // Faz 4: original DOCX bytes preserved for redline round-trip.
  // Nullable so pre-Faz-4 rows remain valid, and so trimOrphanDocxBuffers
  // can null this out under the TTL policy after a retention window.
  originalDocxBuffer Bytes?
  createdAt DateTime @default(now())
}

// ─── Edit Proposal (Faz 4) ────────────────────────────
//
// Raw clause-level edit suggested by an agent during the agent pass.
// Many per run; chief arbitration consolidates them into ArbitratedEdit.

model EditProposal {
  id           String   @id @default(cuid())
  runId        String
  run          BoardRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  agentKey     String
  clauseRef    String
  editType     String // "replace_clause" | "replace_phrase" | "insert_after" | "delete_clause"
  originalText String?  @db.Text
  proposedText String   @db.Text
  rationale    String   @db.Text
  severity     String // "critical" | "warning" | "info"
  createdAt    DateTime @default(now())

  @@index([runId])
  @@index([runId, clauseRef])
}

// ─── Arbitrated Edit (Faz 4) ──────────────────────────
//
// Chief's canonical decision per clause/phrase. sourceProposals lists
// the EditProposal IDs that fed this arbitration (trace + audit).
// resolution captures which proposal(s) the chief accepted.

model ArbitratedEdit {
  id                String   @id @default(cuid())
  runId             String
  run               BoardRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  clauseRef         String
  editType          String
  originalText      String?  @db.Text
  finalText         String   @db.Text
  sourceProposals   String[] // EditProposal IDs
  arbitrationNote   String   @db.Text
  resolution        String // "accepted_a" | "accepted_b" | "merged" | "rewritten" | "rejected_all" | "orphan_unmatched"
  finalSeverity     String // "critical" | "warning" | "info" — chief may raise/lower
  createdAt         DateTime @default(now())

  @@index([runId])
  @@index([runId, resolution])
}

// ─── Redline Artifact (Faz 4) ─────────────────────────
//
// Generated track-changes DOCX. Versioned per run: every regeneration
// marks previous rows isLatest=false and creates a new one with
// generation+1. GET endpoint defaults to isLatest=true; ?generation=N
// returns a specific version.

model RedlineArtifact {
  id           String   @id @default(cuid())
  runId        String
  run          BoardRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  generation   Int
  isLatest     Boolean  @default(true)
  docxBuffer   Bytes
  editCount    Int
  orphanCount  Int
  generatedAt  DateTime @default(now())

  @@unique([runId, generation])
  @@index([runId])
  @@index([runId, isLatest])
}

// ─── Agent Opinion ────────────────────────────────────

model AgentOpinion {
  id        String   @id @default(cuid())
  runId     String
  run       BoardRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  agentKey  String
  agentName String
  type      String // "observation" | "analysis" | "objection"
  topic     String
  message   String @db.Text
  data      Json?  // structured opinion payload
  timestamp BigInt // absolute epoch ms (Date.now())
  createdAt DateTime @default(now())

  @@index([runId])
  @@index([runId, agentKey])
}

// ─── Debate Moment ────────────────────────────────────

model DebateMoment {
  id        String   @id @default(cuid())
  runId     String
  run       BoardRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  agentKey  String
  agentName String
  type      String // DebateEventType enum values
  topic     String
  message   String @db.Text
  metadata  Json?  // optional enrichment
  timestamp BigInt // absolute epoch ms (Date.now())
  createdAt DateTime @default(now())

  @@index([runId])
  @@index([runId, type])
}

// ─── Final Verdict ────────────────────────────────────

model FinalVerdict {
  id              String   @id @default(cuid())
  runId           String   @unique
  run             BoardRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  summary         String   @db.Text
  riskLevel       String // "high" | "medium" | "low"
  confidenceLevel String? // "high" | "medium" | "low"
  decisions       Json // string[]
  actionItems     Json // string[]
  agentPerspectives Json // Array<{ agentId, agentName, avatar, position }>
  disagreements     Json // Array<{ topic, agentA, agentB, resolution }>
  // NOTE: Faz 4'te multi-round debate gelince
  // resolvedDisagreements -> VerdictDisagreement tablosuna,
  // positionChanges -> VerdictPositionChange tablosuna normalize edilecek.
  resolvedDisagreements   Json?
  unresolvedDisagreements Json?
  positionChanges         Json?
  createdAt DateTime @default(now())

  @@index([runId])
}

// ─── Audit Log ────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  action     String // cv_draft_saved, run_created, etc.
  targetType String // "agent" | "run" | "template"
  targetId   String?
  summary    String
  module     String? // boardroom | draft | compare | signatures | control_room | system
  severity   String  @default("info") // debug | info | warning | error | critical
  metadata   Json?
  requestId  String?
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  timestamp  DateTime @default(now())

  @@index([actorId])
  @@index([module])
  @@index([severity])
  @@index([requestId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([timestamp])
}

// ─── Regulations Feed ─────────────────────────────────
//
// Param Grubu için ilgili mevzuat ve kurum kararlarının canlı
// takibi. Boardroom pipeline'ından bağımsız ayrı katman; case-law-
// researcher agent'ı boardroom akışında, RegulationItem ise
// /app/regulations sayfasında yaşar. Topic taxonomy (e-para,
// MASAK, KVKK, vergi, BDDK, ticari, kurumsal) src/lib/regulations/
// topics.ts içinde hardcoded. Bir item birden fazla topic'e
// bağlanabilir.

model RegulationItem {
  id           String   @id @default(cuid())
  // Kaynağın ID'si (yargi-mcp, resmi-gazete, tcmb, bddk, kvkk,
  // masak, gib, …) — UI'da kaynak rozeti için kullanılır.
  source       String
  // Kaynak tarafındaki ID veya URL hash — (source, externalId)
  // UNIQUE üzerinden idempotent upsert.
  externalId   String
  title        String
  summary      String   @db.Text
  bodyExcerpt  String?  @db.Text
  url          String?
  publishedAt  DateTime
  fetchedAt    DateTime @default(now())
  // Topic id listesi — String[] (Postgres native array). Filter
  // sayısı az (≤7) olduğu için index'siz kalır.
  topics       String[]
  priority     String   // "critical" | "high" | "medium" | "low"
  // Ham kaynak yanıtı (debug + future reclassify); 50KB cap
  // server tarafında uygulanır.
  rawPayload   Json?

  reads RegulationRead[]

  @@unique([source, externalId])
  @@index([publishedAt])
  @@index([priority])
  @@index([source])
}

model RegulationRead {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  regulationId  String
  regulation    RegulationItem @relation(fields: [regulationId], references: [id], onDelete: Cascade)
  readAt        DateTime       @default(now())
  pinned        Boolean        @default(false)

  @@unique([userId, regulationId])
  @@index([userId])
}
