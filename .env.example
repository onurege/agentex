# ─── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://agentex:agentex_dev@localhost:5433/agentex?schema=public"

# ─── NextAuth ─────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Gemini AI ────────────────────────────────────────
GEMINI_API_KEY=

# ─── Persistence Mode ────────────────────────────────
# "local" = localStorage (default), "db" = PostgreSQL
NEXT_PUBLIC_PERSISTENCE_MODE=local

# ─── Roles (env-allowlist, Faz 2'de DB-backed olacak) ─
NEXT_PUBLIC_SUPER_ADMINS=
NEXT_PUBLIC_AUTHORIZED_USERS=
