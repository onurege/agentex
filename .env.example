# ─── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://agentex:agentex_dev@localhost:5433/agentex?schema=public"

# ─── NextAuth ─────────────────────────────────────────
# REQUIRED — dev bypass yok; credentials olmadan /app erişilemez.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────
# Console: authorized redirect URI = <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Initial Super Admin ──────────────────────────────
# İlk login'de bu email super_admin'e promote edilir (idempotent).
# Promote edildikten sonra kaldırılabilir — rol DB'de kalır.
INITIAL_SUPER_ADMIN_EMAIL=

# ─── Gemini AI ────────────────────────────────────────
GEMINI_API_KEY=

# ─── Persistence Mode ────────────────────────────────
# "local" = localStorage (default), "db" = PostgreSQL
NEXT_PUBLIC_PERSISTENCE_MODE=local
