# ─── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://agentex:agentex_dev@localhost:5433/agentex?schema=public"

# ─── NextAuth ─────────────────────────────────────────
# REQUIRED — dev bypass yok; credentials olmadan /app erişilemez.
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────
# Console: authorized redirect URI = <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Initial Super Admin ──────────────────────────────
# İlk login'de bu email super_admin'e promote edilir (idempotent).
# Promote edildikten sonra kaldırılabilir — rol DB'de kalır.
INITIAL_SUPER_ADMIN_EMAIL=

# ─── Gemini AI ────────────────────────────────────────
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# ─── Boardroom Pipeline Flags (Faz 4) ────────────────
# Optional passes. Default off — disabling both brings the pipeline
# latency from ~60s to ~25s on gemini-2.5-flash. Turn either on for
# debate-heavy documents where the explicit disagreement + rebuttal
# rounds earn their extra time cost.
BOARDROOM_ENABLE_DISAGREEMENT_PASS=false
BOARDROOM_ENABLE_REBUTTAL_PASS=false

# ─── Persistence Mode ────────────────────────────────
# "local" = localStorage (default), "db" = PostgreSQL
NEXT_PUBLIC_PERSISTENCE_MODE=local
